# Django Ortam Değişkenleri Örneği
# Bu dosyayı .env adıyla kaydedin ve bilgileri doldurun.

# Güvenlik ve Hata Ayıklama
# Local (Yerel) İçin: DEBUG=True
# Canlı (Sunucu) İçin: DEBUG=False
DEBUG=True

# Secret Key (Django için gizli anahtar - Sunucuda değiştirmeyi unutmayın!)
SECRET_KEY=django-insecure-test-key-replace-in-production-12345

# İzin Verilen Hostlar (Virgülle ayırın)
# Örnek: localhost,127.0.0.1,aylinbalkan.pythonanywhere.com
ALLOWED_HOSTS=localhost,127.0.0.1,* 

# Veritabanı Yapılandırması (SQLite için dokunmanıza gerek yok)
DB_NAME=db.sqlite3
